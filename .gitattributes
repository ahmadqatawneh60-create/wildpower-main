# Auto detect text files and perform LF normalization
* text=auto

# Explicitly set MIME types for web assets
*.js text eol=lf diff=javascript
*.css text eol=lf diff=css
*.json text eol=lf
*.html text eol=lf diff=html
*.ts text eol=lf diff=typescript
*.tsx text eol=lf diff=typescript
*.jsx text eol=lf diff=javascript

# Ensure dist files maintain proper line endings
dist/**/*.js text eol=lf
dist/**/*.css text eol=lf

